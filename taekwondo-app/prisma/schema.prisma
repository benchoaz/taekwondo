datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  engineType      = "binary"
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          String    @default("MEMBER") // "ADMIN", "COACH", "MEMBER"
  fcmToken      String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  member        Member?
  coach         Coach?
  receivedPayments Payment[] @relation("PaymentReceiver")
}

model Account {
  id                 String  @id @default(uuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Member {
  id             String        @id @default(uuid())
  userId         String        @map("user_id") @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String        @map("full_name")
  memberNumber   String        @map("member_number") @unique
  currentBelt    String        @default("Sabuk Putih (10 Geup)") @map("current_belt")
  progress       Int           @default(0)
  status         String        @default("PENDING_VERIFICATION")
  selfieUrl      String?       @map("selfie_url")         // Foto profil member
  kkUrl          String?       @map("kk_url")             // Kartu Keluarga
  paymentProofUrl String?      @map("payment_proof_url")  // Bukti bayar registrasi
  certDocUrl     String?       @map("cert_doc_url")       // Sertifikat sabuk / UKT
  phone          String?       @map("phone")              // Nomor WhatsApp
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  dateOfBirth    DateTime?     @map("date_of_birth")
  weight         Float?        @map("weight")             // Berat Badan (kg)
  height         Float?        @map("height")             // Tinggi Badan (cm)
  waistCircum    Float?        @map("waist_circum")       // Lingkar Perut (cm)
  beltHistory    BeltHistory[]
  uktEntries     UktParticipant[]
  certificates   Certificate[]
  payments       Payment[]
  attendances    Attendance[]
  achievements   Achievement[]
  sppInvoices    SppInvoice[]
  exerciseLogs   MemberExerciseLog[]
  badges         MemberBadge[]
  dailyQuestLogs DailyQuestLog[]
}

model Coach {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String   @map("full_name")
  danRank      String   @map("dan_rank") // e.g. "Dan 4", "Dan 6"
  specialty    String   @default("Kyorugi & Poomsae")
  experience   String   @default("10+ Tahun")
  photoUrl     String?  @map("photo_url")     // Foto profil pelatih (base64 atau URL)
  certDocUrl   String?  @map("cert_doc_url")  // Sertifikat Kukkiwon / KTA / lisensi
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  uktExams     UktExam[] // Exams verified or conducted by this coach
  schedules    Schedule[] // Jadwal latihan yang diampu
}

model BeltRank {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "Sabuk Putih (10 Geup)"
  level       Int      // Higher value = higher rank, or custom order
  nextBeltId  String?  @map("next_belt_id")

  // Belt Requirements
  minAttendance Int @default(80) @map("min_attendance") // Persentase kehadiran
  minTechScore  Int @default(70) @map("min_tech_score")
  minPoomsae    Int @default(70) @map("min_poomsae")
  minPhysical   Int @default(70) @map("min_physical")

  categories    CurriculumCategory[]
}

model BeltHistory {
  id           String   @id @default(uuid())
  memberId     String   @map("member_id")
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fromBelt     String   @map("from_belt")
  toBelt       String   @map("to_belt")
  promotedAt   DateTime @default(now()) @map("promoted_at")
}

model UktExam {
  id           String   @id @default(uuid())
  title        String
  date         DateTime
  location     String
  examinerId   String?  @map("examiner_id")
  examiner     Coach?   @relation(fields: [examinerId], references: [id], onDelete: SetNull)
  status       String   @default("UPCOMING") // "UPCOMING", "ONGOING", "COMPLETED"
  createdAt    DateTime @default(now())
  participants UktParticipant[]
}

model UktParticipant {
  id           String    @id @default(uuid())
  uktExamId    String    @map("ukt_exam_id")
  uktExam      UktExam   @relation(fields: [uktExamId], references: [id], onDelete: Cascade)
  memberId     String    @map("member_id")
  member       Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  targetBelt   String    @map("target_belt")
  status       String    @default("PENDING") // "PENDING", "APPROVED", "GRADED", "REMEDIAL", "FAILED"
  
  // Penilaian UKT Components
  poomsaeScore     Float @default(0) @map("poomsae_score")
  kyorugiScore     Float @default(0) @map("kyorugi_score")
  basicTechScore   Float @default(0) @map("basic_tech_score")
  physicalScore    Float @default(0) @map("physical_score")
  theoryScore      Float @default(0) @map("theory_score")
  finalScore       Float @default(0) @map("final_score")
  
  permissionLetter String?   @map("permission_letter") // Path/URL
  photoUrl         String?   @map("photo_url")
  uploadedDocs     Json?     @map("uploaded_docs")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Certificate {
  id             String   @id @default(uuid())
  memberId       String   @map("member_id")
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  certNumber     String   @unique @map("cert_number")
  oldBelt        String   @map("old_belt")
  newBelt        String   @map("new_belt")
  issueDate      DateTime @default(now()) @map("issue_date")
  qrCodeUrl      String   @map("qr_code_url")
  isValid        Boolean  @default(true) @map("is_valid")
  createdAt      DateTime @default(now())
}

model Article {
  id        String   @id @default(uuid())
  title     String
  content   String
  author    String
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gallery {
  id        String   @id @default(uuid())
  imageUrl  String   @map("image_url")
  category  String   // "UKT", "KEJUARAAN", "LATIHAN", "SEMINAR"
  title     String?
  createdAt DateTime @default(now())
}

model Achievement {
  id          String   @id @default(uuid())
  memberId    String   @map("member_id")
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  title       String   // e.g., "Juara 1 Kyorugi Putra U-45"
  eventName   String   @map("event_name") // e.g., "Kejurda DKI Jakarta 2024"
  date        DateTime
  rank           String?  // e.g., "Emas", "Perak", "Perunggu"
  photoUrl       String?  @map("photo_url")
  certificateUrl String?  @map("certificate_url") // Bukti Piagam
  status         String   @default("PENDING")     // "PENDING", "APPROVED", "REJECTED"
  createdAt      DateTime @default(now())
}

model Payment {
  id              String    @id @default(uuid())
  memberId        String    @map("member_id")
  member          Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount          Float
  purpose         String
  status          String    @default("PENDING") // "PENDING", "COMPLETED", "OVERDUE", "FAILED"
  paymentMethod   String    @default("TRANSFER_MANUAL") @map("payment_method") // "QRIS_ONLINE", "TRANSFER_MANUAL", "TUNAI_CASH"
  dueDate         DateTime? @map("due_date")
  paymentProofUrl String?   @map("payment_proof_url")
  externalId      String?   @map("external_id")   // ID unik transaksi Xendit QRIS
  paidAt          DateTime? @map("paid_at")        // Timestamp pembayaran dari webhook Xendit
  receivedById    String?   @map("received_by_id")
  receiver        User?     @relation(name: "PaymentReceiver", fields: [receivedById], references: [id])
  createdAt       DateTime  @default(now())
  sppInvoice      SppInvoice?
}

model SppInvoice {
  id          String   @id @default(uuid())
  memberId    String   @map("member_id")
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  amount      Float
  dueDate     DateTime @map("due_date")
  status      String   @default("UNPAID") // "UNPAID", "PAID", "OVERDUE"
  paymentId   String?  @map("payment_id") @unique
  payment     Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([memberId, month, year])
}

model Expense {
  id              String   @id @default(uuid())
  amount          Float
  description     String
  date            DateTime @default(now())
  recordedBy      String?  @map("recorded_by") // Admin/Bendahara Name
  createdAt       DateTime @default(now())
}

model Attendance {
  id        String   @id @default(uuid())
  memberId  String   @map("member_id")
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  date      DateTime
  present   Boolean  @default(true)
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  userId    String           @map("user_id")
  type      NotificationType @default(ANNOUNCEMENT)
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now())
}

enum NotificationType {
  EVENT
  SPP
  UKT
  ANNOUNCEMENT
  QUEST
}

model Setting {
  id              String   @id @default("default")
  logoUrl         String?  @map("logo_url")
  heroBgUrl       String?  @map("hero_bg_url")
  dojangName      String   @default("TAEKWONDO ACADEMY") @map("dojang_name")
  motto           String   @default("Disiplin • Integritas • Prestasi")
  heroTitle       String   @default("TAEKWONDO ACADEMY - Bangun Mental Juara, Disiplin dan Prestasi Bersama Kami") @map("hero_title")
  description     String   @default("Membangun karakter pemenang melalui dedikasi fisik, moral tinggi, dan prestasi yang terstruktur.")
  address         String   @default("Jl. Pahlawan Olahraga No. 88, Senayan, Jakarta Selatan, DKI Jakarta")
  email           String   @default("info@taekwondo.com")
  phone           String   @default("+62 812-3456-7890")
  registrationFee Float    @default(150000) @map("registration_fee")
  sppFee          Float    @default(100000) @map("spp_fee")
  sessionFee      Float    @default(15000) @map("session_fee")
  uktFee          Float    @default(150000) @map("ukt_fee")
  uktRequirements Json?    @map("ukt_requirements")
  uktFees         Json?    @map("ukt_fees")
  showIntro       Boolean  @default(true) @map("show_intro")
  dojangLat       Float?   @map("dojang_lat")
  dojangLng       Float?   @map("dojang_lng")
  dojangRadius    Int      @default(100) @map("dojang_radius")
  updatedAt       DateTime @updatedAt
}

model Schedule {
  id          String   @id @default(uuid())
  dayOfWeek   String   @map("day_of_week") // "Senin", "Selasa", dll
  startTime   String   @map("start_time")  // "17:00"
  endTime     String   @map("end_time")    // "19:00"
  className   String   @map("class_name")  // "Kelas Pemula (Kids)"
  location    String   
  coachId     String   @map("coach_id")
  coach       Coach    @relation(fields: [coachId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(uuid())
  imageUrl  String   @map("image_url")
  caption   String?
  subtext   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// LMS & CMS ADDITIONS
// ==========================================

model CurriculumCategory {
  id       String   @id @default(uuid())
  beltId   String   @map("belt_id")
  belt     BeltRank @relation(fields: [beltId], references: [id], onDelete: Cascade)
  name     String   // "Teknik Dasar", "Poomsae", "Fisik"
  order    Int      @default(0)
  materials CurriculumMaterial[]
}

model CurriculumMaterial {
  id         String   @id @default(uuid())
  categoryId String   @map("category_id")
  category   CurriculumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title      String   // "Ap Chagi", "Taegeuk 2"
  videoUrl   String?  @map("video_url")
  order      Int      @default(0)
}

model TrainingProgram {
  id          String   @id @default(uuid())
  title       String   // "Program Latihan Minggu 1"
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now())
  exercises   Exercise[]
}

model Exercise {
  id        String   @id @default(uuid())
  programId String   @map("program_id")
  program   TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  name      String   // "Push Up"
  reps      Int?     // 50
  sets      Int?     // 3
  order     Int      @default(0)
  memberLogs MemberExerciseLog[]
}

model MemberExerciseLog {
  id          String   @id @default(uuid())
  memberId    String   @map("member_id")
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  exerciseId  String   @map("exercise_id")
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now()) @map("completed_at")
  notes       String?  // Siswa mengisi apa yang dilakukan di rumah
}

model Badge {
  id          String   @id @default(uuid())
  name        String   // "Master Ap Chagi"
  iconUrl     String   @map("icon_url")
  description String?
  condition   String   // Identifier rule logika (contoh: "STREAK_7")
  members     MemberBadge[]
}

model MemberBadge {
  id       String   @id @default(uuid())
  memberId String   @map("member_id")
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  badgeId  String   @map("badge_id")
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now()) @map("earned_at")
}

model VirtualCoachRule {
  id        String   @id @default(uuid())
  condition String   // "TECH_SCORE < 70"
  recommend String   // "Fokus latihan keseimbangan kuda-kuda"
}

// ==========================================
// DAILY QUEST GAMIFICATION
// ==========================================

enum QuestCategory {
  FITNESS
  TECHNICAL
  DISCIPLINE
  THEORY
}

model QuestLibrary {
  id          String        @id @default(uuid())
  title       String
  description String?       @db.Text
  category    QuestCategory
  baseXp      Int           @default(50) @map("base_xp")
  videoUrl    String?       @map("video_url")
  requireVideo Boolean       @default(false) @map("require_video")
  requirements QuestRequirement[]
  logs         DailyQuestLog[]
  createdAt   DateTime      @default(now())
}

model QuestRequirement {
  id             String       @id @default(uuid())
  questId        String       @map("quest_id")
  quest          QuestLibrary @relation(fields: [questId], references: [id], onDelete: Cascade)
  minAge         Int          @default(0) @map("min_age")
  maxAge         Int          @default(99) @map("max_age")
  allowedBeltIds String[]     @map("allowed_belt_ids")
}

model DailyQuestLog {
  id          String       @id @default(uuid())
  memberId    String       @map("member_id")
  member      Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  questId     String       @map("quest_id")
  quest       QuestLibrary @relation(fields: [questId], references: [id], onDelete: Cascade)
  completed   Boolean      @default(false)
  completedAt DateTime?    @map("completed_at")
  assignedAt  DateTime     @default(now()) @map("assigned_at")
  videoUrl    String?      @map("video_url") // For verification
  notes       String?      @db.Text
}

// ==========================================
// TOURNAMENT & EVENTS AGGREGATOR
// ==========================================

model TournamentEvent {
  id             String   @id @default(uuid())
  title          String
  level          String   @default("Provinsi") // "Lokal", "Provinsi", "Nasional", "Internasional"
  location       String   @default("Belum Ditentukan")
  startDate      DateTime 
  endDate        DateTime
  posterUrl      String?  @map("poster_url")
  proposalUrl    String?  @map("proposal_url")
  source         String   @default("AUTOMATIC_RSS") // "AUTOMATIC_RSS", "USER_SUBMITTED"
  status         String   @default("PUBLISHED") // "PENDING", "PUBLISHED", "REJECTED"
  link           String?  // Link berita atau link asli acara
  createdAt      DateTime @default(now())
}

