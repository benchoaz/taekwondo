# Containerfile untuk Next.js Taekwondo App (Kompatibel dengan Podman Rootless)

FROM node:20-alpine AS base

# Install openssl untuk engines Prisma
RUN apk add --no-cache openssl wget

# Setup dependencies
FROM base AS deps
WORKDIR /app
COPY package*.json ./
RUN npm install --legacy-peer-deps

# Builder stage
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Generate Prisma Client & Build
ENV NEXT_TELEMETRY_DISABLED=1
RUN npx prisma generate
RUN npm run build

# Runner stage
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3030
ENV HOSTNAME="0.0.0.0"

# Best practice keamanan: Jangan jalankan container sebagai root
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public

# Setup folder standalone Next.js dan ownership permissions
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/prisma ./prisma
COPY --chown=nextjs:nodejs firebase-service-account.json ./firebase-service-account.json

USER nextjs

EXPOSE 3030

# Healthcheck untuk monitoring status container
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3030/ || exit 1

CMD ["node", "server.js"]
